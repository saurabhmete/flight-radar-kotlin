#pragma once

// ── WiFi ─────────────────────────────────────────────────────────────────────
#define WIFI_SSID       "YourNetworkName"
#define WIFI_PASSWORD   "YourPassword"

// ── Backend ──────────────────────────────────────────────────────────────────
// Point this at your RPi (local IP or Tailscale hostname)
#define API_HOST        "http://192.168.x.x:8000"
#define API_ENDPOINT    "/api/flights"

// ── Display ──────────────────────────────────────────────────────────────────
#define SCREEN_W        320
#define SCREEN_H        480

// AXS15231B via QSPI
#define LCD_CS          45
#define LCD_CLK         47
#define LCD_D0          21
#define LCD_D1          48
#define LCD_D2          40
#define LCD_D3          39
#define LCD_BL          1    // backlight

// AXS15231B touch via I2C
#define TOUCH_SDA       4
#define TOUCH_SCL       8
#define TOUCH_INT       11
#define TOUCH_RST       12
#define TOUCH_ADDR      0x3B
#define TOUCH_I2C_HZ    400000

// ── Observer location (matches web app) ──────────────────────────────────────
#define OBSERVER_LAT   51.505f
#define OBSERVER_LON    7.466f
#define RADAR_MAX_KM   40.0f

// ── Spotify ───────────────────────────────────────────────────────────────────
// Run arduino/spotify_auth.py once to get these values.
// In Spotify Developer Dashboard, set Redirect URI to: http://127.0.0.1:8888/callback
// (HTTP is allowed for loopback IPs; "localhost" is blocked by Spotify's April 2025 policy)
#define SPOTIFY_CLIENT_ID     "your_client_id_here"
#define SPOTIFY_CLIENT_SECRET "your_client_secret_here"
#define SPOTIFY_REFRESH_TOKEN "your_refresh_token_here"

// ── App ───────────────────────────────────────────────────────────────────────
#define FETCH_INTERVAL_MS  15000UL   // refresh every 15 s (matches web)
#define MAX_FLIGHTS        3         // 1 primary + 2 compact
